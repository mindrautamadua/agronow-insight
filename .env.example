# ─────────────────────────────────────────────────────────────────────────────
# Agronow Learning & Development — environment
# Copy this file to `.env.local` and fill in your MySQL credentials.
# ─────────────────────────────────────────────────────────────────────────────

# MySQL connection
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=agronow_ld

# Connection pool size (optional)
MYSQL_POOL_LIMIT=10
